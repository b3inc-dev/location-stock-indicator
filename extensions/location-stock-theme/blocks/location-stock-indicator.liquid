{% comment %}
  Theme app extension block: Location stock indicator
  - 商品ページ用ブロック
  - 実際の UI と JS は snippets/location-stock-indicator.liquid に委譲
{% endcomment %}

{% if product %}
  {% render 'location-stock-indicator',
    product: product,
    config: block.settings,
    root_id: block.id
  %}
{% else %}
  <p>このブロックは商品ページでのみ表示されます。</p>
{% endif %}

{% schema %}
{
  "name": "Location stock indicator",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "タイトルとレイアウト"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "タイトル",
      "default": "各店舗の在庫状況",
      "info": "空欄のままにするとタイトルを表示しません。"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "タイトルの揃え",
      "default": "left",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "タイトル下マージン（px）",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "タイトルの色"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "タイトルの文字サイズ（px）",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "レイアウト",
      "default": "list",
      "options": [
        { "value": "table", "label": "表（テーブル）" },
        { "value": "list", "label": "リスト（1行）" },
        { "value": "stacked", "label": "2行（ロケーション名＋在庫）" }
      ]
    },
    {
      "type": "select",
      "id": "location_align",
      "label": "ロケーション名の揃え",
      "default": "left",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },
    {
      "type": "select",
      "id": "status_align",
      "label": "在庫表示の揃え",
      "default": "right",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "ブロックの文字サイズ（リスト・凡例・注意書き）（px）",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 16,
      "info": "リスト・凡例・注意書きに共通で適用されます。"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "上マージン（px）",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "下マージン（px）",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "最大幅（px）",
      "info": "0 にすると横幅いっぱい（100%）で表示します。",
      "min": 0,
      "max": 1200,
      "step": 20,
      "default": 600
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "ブロック全体の配置",
      "default": "left",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央寄せ" },
        { "value": "right", "label": "右寄せ" }
      ]
    },

    {
      "type": "header",
      "content": "凡例・注意書き・行・枠線・色"
    },
    {
      "type": "select",
      "id": "legend_position",
      "label": "凡例の表示位置",
      "default": "bottom",
      "options": [
        { "value": "top", "label": "リストの上" },
        { "value": "bottom", "label": "リストの下" }
      ]
    },
    {
      "type": "select",
      "id": "legend_align",
      "label": "凡例の揃え",
      "default": "left",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },
    {
      "type": "color",
      "id": "legend_color",
      "label": "凡例の色"
    },
    {
      "type": "select",
      "id": "notice_position",
      "label": "注意書きの位置",
      "default": "bottom",
      "options": [
        { "value": "top", "label": "リストの上" },
        { "value": "bottom", "label": "リストの下" }
      ]
    },
    {
      "type": "select",
      "id": "notice_align",
      "label": "注意書きの揃え",
      "default": "left",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },
    {
      "type": "color",
      "id": "notice_color",
      "label": "注意書きの色"
    },
    {
      "type": "range",
      "id": "row_padding_y",
      "label": "行の上下余白（px）",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "row_padding_x",
      "label": "行の左右余白（px）",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "location_col_width",
      "label": "テーブルレイアウト時のロケーション列の幅（%）",
      "min": 30,
      "max": 80,
      "step": 5,
      "default": 70
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "枠線のスタイル",
      "default": "rows",
      "options": [
        { "value": "none", "label": "枠線なし" },
        { "value": "rows", "label": "行ごとのみ" },
        { "value": "full", "label": "外枠＋行ごと" }
      ]
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "枠線の太さ（px）",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "枠線の色",
      "default": "#e3e3e3"
    },
    {
      "type": "color",
      "id": "status_text_color",
      "label": "在庫ステータス（行内テキスト）の色"
    },
    {
      "type": "color",
      "id": "in_stock_color",
      "label": "在庫ありマークの色（◯）"
    },
    {
      "type": "color",
      "id": "low_stock_color",
      "label": "残りわずかマークの色（△）"
    },
    {
      "type": "color",
      "id": "out_of_stock_color",
      "label": "在庫なしマークの色（✕）"
    },

    {
      "type": "header",
      "content": "エリア/近隣店舗のデザイン"
    },
    {
      "type": "paragraph",
      "content": "「エリアでグルーピング」の地域見出し行と「近隣店舗」見出しの両方に同じデザインが反映されます。アプリのロケーション設定で指定した値よりこちらが優先されます。"
    },
    {
      "type": "select",
      "id": "region_heading_align",
      "label": "見出しの配置",
      "default": "left",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },
    {
      "type": "color",
      "id": "region_heading_background",
      "label": "背景色"
    },
    {
      "type": "color",
      "id": "region_heading_color",
      "label": "文字色"
    },
    {
      "type": "range",
      "id": "region_heading_font_size",
      "label": "文字サイズ（px）",
      "min": 8,
      "max": 20,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "region_heading_padding",
      "label": "余白（px）",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "select",
      "id": "accordion_icon",
      "label": "エリア折りたたみの開閉マーク",
      "default": "chevron",
      "options": [
        { "value": "chevron", "label": "三角（▼/▶）" },
        { "value": "angle", "label": "山括弧（＞/∨）" },
        { "value": "plus_minus", "label": "プラス・マイナス（+/−）" },
        { "value": "arrow", "label": "矢印（↓/→）" }
      ],
      "info": "エリア・近隣店舗の見出しで「折りたたみ表示」をONにしたときの見出し右のマークです。"
    },
    {
      "type": "header",
      "content": "店舗受け取りボタン"
    },
    {
      "type": "paragraph",
      "content": "ボタンの種類と色を設定します。アプリのロケーション設定でボタン表示をONにしたときのみ表示されます。"
    },
    {
      "type": "select",
      "id": "order_pick_btn_style",
      "label": "ボタンの種類",
      "default": "solid_round",
      "options": [
        { "value": "solid_square", "label": "ソリッド×スクエア" },
        { "value": "solid_round", "label": "ソリッド×ラウンド" },
        { "value": "solid_pill", "label": "ソリッド×ピル" },
        { "value": "outline_square", "label": "アウトライン×スクエア" },
        { "value": "outline_round", "label": "アウトライン×ラウンド" },
        { "value": "outline_pill", "label": "アウトライン×ピル" },
        { "value": "ghost", "label": "ゴースト" }
      ]
    },
    {
      "type": "color",
      "id": "order_pick_btn_background",
      "label": "ボタン背景色"
    },
    {
      "type": "color",
      "id": "order_pick_btn_color",
      "label": "ボタン文字色"
    },
    {
      "type": "range",
      "id": "order_pick_btn_font_size",
      "label": "ボタンの文字サイズ（px）",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "order_pick_btn_padding",
      "label": "ボタンの文字余白（px）",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "order_pick_col_width",
      "label": "ボタン列の幅（テーブル時・%）",
      "min": 15,
      "max": 45,
      "step": 5,
      "default": 25,
      "info": "テーブル表示でボタン表示時のみ有効です。\n幅が不足する場合はボタン列はボタン幅の最大値になります。画面の50%を超える場合は、ボタンをロケーション・在庫の下の行に100%幅で表示します（受取不可店舗はボタン行なし）。"
    },
    {
      "type": "select",
      "id": "order_pick_btn_align",
      "label": "ボタンの左右位置",
      "default": "right",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ]
    },

    {
      "type": "textarea",
      "id": "custom_css",
      "label": "追加CSS",
      "default": "/* custom CSS */",
      "info": "ルート要素の ID は block に基づきます。スタイルを上書きする場合は #lsi-（blockのID） をセレクタに使えます。"
    }
  ]
}
{% endschema %}
